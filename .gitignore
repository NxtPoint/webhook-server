# Python bytecode / caches
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual envs & editor junk
.venv/
venv/
.env
.DS_Store
.vscode/
.idea/

# Generated data & artifacts
data/*
!data/.gitkeep
result_*.json

# ML pipeline model weights (large binary files)
ml_pipeline/models/*.pt
ml_pipeline/models/*.pth
ml_pipeline/models/*.pth.tar
ml_pipeline/models/*.onnx

# ML pipeline training artifacts
ml_pipeline/training/datasets/
ml_pipeline/training/labels/
ml_pipeline/training/visual_debug/
ml_pipeline/training/_dataset_cache/

# Test video clips
ml_pipeline/test_videos/

# Claude Code tool local artefacts (debug outputs, task locks, worktrees,
# local settings). The .claude/ folder itself is tracked because handover
# docs live there — but these per-run artefacts shouldn't be.
.claude/debug_frames_*/
.claude/eval_*.txt
.claude/reconcile_*.txt
.claude/run_status_*.md
.claude/silver_rebuild_*.txt
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/worktrees/
.claude/tmp/

# Eval history (per-machine; grown incrementally by harness)
ml_pipeline/eval_history.jsonl

# Serve-detector local diagnostics — contact-sheet PNGs + pose dumps
diag_*/
# Exception: diag_sql/ is the read-only SQL ops endpoint (code module, not output).
!diag_sql/
ml_pipeline/diag/local_poses_*.jsonl

# Ad-hoc user files at repo root (PDFs, screenshots, quick notes)
/*.pdf
/*.png

# Diag outputs — per-task data files, can be regenerated
ml_pipeline/diag/*.jsonl
ml_pipeline/diag/local_poses_*.jsonl
ml_pipeline/diag/prod_pose_audit_*.json
ml_pipeline/diag/visual_debug/

# Detector test-harness fixtures (snapshot_task output). Gitignored —
# regenerate from DB with `python -m ml_pipeline.diag.snapshot_task ...`.
# Locally these are 50-100 MB each.
ml_pipeline/fixtures/*.pkl.gz
ml_pipeline/fixtures/*.pkl
# Silver-bench bronze fixtures. Same pattern — large, regenerable from DB
# via `python -m ml_pipeline.diag.bench_silver.snapshot`, durable backup
# lives in s3://nextpoint-prod-uploads/fixtures/silver/.
ml_pipeline/fixtures_silver/*.sql.gz
# bench_baseline.json IS committed (it's the regression baseline tied to
# the current commit's numbers — you want it diff-visible when it changes).
# Same applies to the per-fixture _silver_baseline.json files — those ARE
# committed.

# Generated weekly SEO reports (seo/weekly_seo.py --out)
seo/reports/

# local read-only DB credential for devenv/seed_local.py — never commit
devenv/.env.local
